# ============================================
# AgentEdge v2 — Environment Configuration
# Copy to .env and fill in. NEVER commit .env.
# ============================================

# --- Execution Mode (CRITICAL) ---
# false = paper trading (safe, simulated fills)
# true  = LIVE trading with real money on MEXC
LIVE_MODE=false

# --- MEXC API (only required when LIVE_MODE=true) ---
MEXC_API_KEY=
MEXC_API_SECRET=

# --- DeepSeek AI Confirmation ---
# Get from https://platform.deepseek.com
DEEPSEEK_KEY=

# --- Telegram Bot ---
# 1. Talk to @BotFather → /newbot → get token
# 2. Send any message to your bot, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    to find your chat ID
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# --- HTTP Dashboard ---
HTTP_PORT=8080

# --- Risk Management ---
MAX_POSITIONS=7
DAILY_LIMIT=800
WEEKLY_LIMIT=3000
MAX_PRICE_DRIFT=0.02
PAPER_STARTING_BALANCE=10000

# --- Strategy Toggles (true/false) ---
ENABLE_SWING_1H=true
ENABLE_VWAP_MACD=true
ENABLE_KELTNER_RSI=true
ENABLE_ALMA_STOCH=true
ENABLE_RSI_BB_REVERT=true

# --- Bot Toggles ---
ENABLE_MONITOR=true
ENABLE_TRIGGER=true
ENABLE_AUTO_SCANNER=true
ENABLE_DISCOVERY=true
ENABLE_CLEANER=true

# --- Bot Timing (seconds) ---
TRIGGER_INTERVAL=2
AUTO_SCAN_INTERVAL=120
DISCOVERY_INTERVAL=60
CLEANER_INTERVAL=300

# --- Signal Thresholds (0-100) ---
TRIGGER_EDGE=65
AUTO_ENTRY=60
AI_MIN_CONFIDENCE=60

# v3 — Advanced Intelligence
ENABLE_COUNCIL=true
ENABLE_MEMORY=true
ENABLE_NEWS_FILTER=true
ENABLE_ADAPTIVE_WEIGHTS=true
ENABLE_BACKTEST_BOT=true
BACKTEST_INTERVAL=21600
